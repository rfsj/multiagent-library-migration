  "description": "Migrate a small analytics project with varied pandas operations: CSV reading, filtering, grouping, joins, pivots, datetime parsing, fillna, sorting and deduplication.",
  "expected_changed_files": [
    "src/analytics/processing.py",
    "requirements.txt"
  ],
  "validity_oracle": {

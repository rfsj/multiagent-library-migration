# Optional metadata recorded in experiment reports.
LLM_MODEL_NAME=gemini-3.1-flash-lite
PYTHON_VERSION=3.11
PANDAS_VERSION=2.2.3
POLARS_VERSION=1.17.1
PYTEST_VERSION=8.3.4

# LLM provider: "anthropic" or "google"
LLM_PROVIDER=google

# Model name for the chosen provider (required)
# Recommended: gemini-3.1-flash-lite (fast, low cost, works with AST fallback)
# Higher capacity: gemini-2.5-pro (slower, may timeout on large files)
LLM_MODEL=gemini-3.1-flash-lite
# LLM_MODEL=gemini-2.5-flash
# LLM_MODEL=gemini-2.5-pro
# LLM_MODEL=claude-sonnet-4-6

# API key for the chosen provider (required)
GOOGLE_API_KEY=your-google-key-here
# ANTHROPIC_API_KEY=your-anthropic-key-here

# Deterministic AST fallback transformer (default: off).
# Set to 1 to apply mechanical pandas→polars fixes after LLM migration.
# Transforms: df["col"]=rhs → with_columns, .reset_index(drop=True) removal,
#             .sort_values() → .sort() with ascending→descending conversion.
# Recommended: enable when using smaller/faster models (flash-lite, flash).
#MIGRATION_USE_AST=1
# MIGRATION_MODE: research (puro) | research_cot | research_fewshot |
#   research_cot_fewshot | assisted. Os modos *_cot usam o v5 (com CoT); os
#   demais research usam o v4 (sem CoT).
MIGRATION_MODE=research

# Override explícito da base do prompt. Comentado => use_cot seleciona v5/v4.
#MIGRATION_PROMPT_FILE=migration_agent_v5.md

# Ablação por camada (sobrescreve o preset). 1/0:
#   MIGRATION_USE_SCANNER / MIGRATION_USE_RESCAN / MIGRATION_USE_AST
#   MIGRATION_USE_SYNTAX_REGEN / MIGRATION_USE_SCOPE
#   MIGRATION_USE_FEWSHOT  (pares de exemplo Human/AI no prompt)
#   MIGRATION_USE_COT      (campo obrigatório migration_plan via MigrationResultCoT)
#MIGRATION_USE_COT=1
#MIGRATION_USE_FEWSHOT=1
